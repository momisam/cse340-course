    <%- include('partials/header') %>
    <main>

    <section class="hero">

        <div class="hero-content">

            <h1><%= title %></h1>

            <h2>Welcome to the CSE 340 Service Network!</h2>

            <p>
                Our mission is to promote service across the world by
                connecting volunteers with service opportunities in
                their community.
            </p>

            <a href="/projects" class="btn">
                Explore Projects
            </a>

        </div>

        <div class="hero-image">

            <img
                class="main-logo"
                src="/images/cse340-service-network.png"
                alt="CSE 340 Service Network Logo">

        </div>

    </section>
    <section class="features">

    <h2>Why Choose CSE 340 Service Network?</h2>

    <div class="feature-grid">

        <article class="feature-card">
            <h3>Community Impact</h3>
            <p>
                Help improve communities by volunteering
                with organizations that need your support.
            </p>
        </article>

        <article class="feature-card">
            <h3>Find Opportunities</h3>
            <p>
                Discover meaningful service projects
                based on your interests and skills.
            </p>
        </article>

        <article class="feature-card">
            <h3>Build Experience</h3>
            <p>
                Gain valuable teamwork and leadership
                experience while serving others.
            </p>
        </article>

    </div>

</section>

</main>
    <%- include ('partials/footer') %>
